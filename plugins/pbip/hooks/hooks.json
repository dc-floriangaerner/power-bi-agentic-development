{
  "description": "Validates PBIP project files (PBIR structure, TMDL syntax, report binding) after Write/Edit and Bash modifications",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-pbir.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-tmdl.sh",
            "timeout": 10,
            "if": "Write|Edit(*.tmdl*)"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-report-binding.sh",
            "timeout": 10,
            "if": "Write|Edit(*definition.pbir*)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-pbir.sh",
            "timeout": 10,
            "if": "Bash(*.Report/*)"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-tmdl.sh",
            "timeout": 10,
            "if": "Bash(*.tmdl*)"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-report-binding.sh",
            "timeout": 10,
            "if": "Bash(*definition.pbir*)"
          }
        ]
      }
    ]
  }
}
